{
  "manifest_version": 3,
  "name": "Download Directory Extension",
  "version": "1.0.0",
  "description": "ON の間、Chrome の既定ダウンロード先の下に開始日時のサブフォルダを付けて保存します。",
  "permissions": [
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Download Directory Extension",
    "default_popup": "popup.html"
  }
}
